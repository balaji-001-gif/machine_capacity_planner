{
  "name": "Machine Selection Settings",
  "doctype": "DocType",
  "module": "Machine Capacity Planner",
  "is_single": 1,
  "is_submittable": 0,
  "description": "Global configuration for machine scoring weights and thresholds.",
  "fields": [
    {
      "fieldname": "section_weights",
      "fieldtype": "Section Break",
      "label": "Scoring Weights"
    },
    {
      "fieldname": "weight_load",
      "fieldtype": "Int",
      "label": "Weight: Utilisation Load %",
      "default": "25",
      "description": "Higher value penalises busy machines more"
    },
    {
      "fieldname": "weight_free_slot",
      "fieldtype": "Int",
      "label": "Weight: Earliest Free Slot",
      "default": "25",
      "description": "Higher value prioritises machines that can start sooner"
    },
    {
      "fieldname": "weight_delivery_slack",
      "fieldtype": "Int",
      "label": "Weight: Delivery Slack",
      "default": "20",
      "description": "Higher value penalises tight delivery windows more"
    },
    {
      "fieldname": "weight_maintenance_risk",
      "fieldtype": "Int",
      "label": "Weight: Maintenance Risk",
      "default": "10",
      "description": "Higher value avoids machines with upcoming maintenance"
    },
    {
      "fieldname": "weight_material_readiness",
      "fieldtype": "Int",
      "label": "Weight: Material Readiness",
      "default": "20",
      "description": "Higher value prefers machines whose free slot aligns with material arrival"
    },
    {
      "fieldname": "section_thresholds",
      "fieldtype": "Section Break",
      "label": "Thresholds and Behaviour"
    },
    {
      "fieldname": "overload_threshold_pct",
      "fieldtype": "Int",
      "label": "Overload Threshold %",
      "default": "92",
      "description": "Utilisation above this triggers capacity alert emails"
    },
    {
      "fieldname": "rebalance_threshold",
      "fieldtype": "Int",
      "label": "Rebalance Min Score Improvement",
      "default": "10",
      "description": "Minimum score improvement needed before reassigning a Job Card"
    },
    {
      "fieldname": "rebalance_interval_mins",
      "fieldtype": "Int",
      "label": "Rebalance Interval (minutes)",
      "default": "30"
    },
    {
      "fieldname": "section_mrp",
      "fieldtype": "Section Break",
      "label": "Material Requirements Planning (MRP)"
    },
    {
      "fieldname": "enable_mrp_check",
      "fieldtype": "Check",
      "label": "Enable MRP Material Check",
      "default": "1",
      "description": "When ON, machine scoring includes material readiness (F5 factor)"
    },
    {
      "fieldname": "material_check_warehouse",
      "fieldtype": "Link",
      "options": "Warehouse",
      "label": "Global Stock Check Warehouse",
      "description": "Warehouse to check for raw material availability (Q2: one global warehouse)"
    },
    {
      "fieldname": "section_notifications",
      "fieldtype": "Section Break",
      "label": "Notifications"
    },
    {
      "fieldname": "manager_email",
      "fieldtype": "Data",
      "label": "Production Manager Email",
      "description": "Receives all capacity alerts, MRP summaries and daily reports",
      "options": "Email"
    },
    {
      "fieldname": "supervisor_email",
      "fieldtype": "Data",
      "label": "Supervisor Email",
      "description": "Receives Critical and Stopped escalation alerts",
      "options": "Email"
    },
    {
      "fieldname": "plant_head_email",
      "fieldtype": "Data",
      "label": "Plant Head Email",
      "description": "Receives Stopped escalation alerts only",
      "options": "Email"
    },
    {
      "fieldname": "section_escalation",
      "fieldtype": "Section Break",
      "label": "Job Card Escalation Thresholds"
    },
    {
      "fieldname": "escalation_warning_hrs",
      "fieldtype": "Float",
      "label": "Warning After (hrs overdue)",
      "default": "0",
      "description": "0 = alert immediately when overdue"
    },
    {
      "fieldname": "escalation_critical_hrs",
      "fieldtype": "Float",
      "label": "Critical After (hrs overdue)",
      "default": "4"
    },
    {
      "fieldname": "escalation_stopped_hrs",
      "fieldtype": "Float",
      "label": "Stopped After (hrs overdue)",
      "default": "8"
    },
    {
      "fieldname": "enable_whatsapp",
      "fieldtype": "Check",
      "label": "Enable WhatsApp Alerts",
      "default": "0"
    },
    {
      "fieldname": "whatsapp_number",
      "fieldtype": "Data",
      "label": "WhatsApp Number (with country code)"
    }
  ],
  "permissions": [
    {
      "role": "Manufacturing Manager",
      "read": 1,
      "write": 1
    },
    {
      "role": "System Manager",
      "read": 1,
      "write": 1
    }
  ]
}
